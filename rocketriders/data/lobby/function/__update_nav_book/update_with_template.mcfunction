# first page spacing
data modify storage rocketriders:navbook first_page_spacing set value ["\n"]

# join teams
execute unless predicate game:gamemode_components/one_team unless predicate game:gamemode_components/red_for_blue run data modify storage rocketriders:navbook join_teams set value ["",{color:"gray",text:"* ",extra:[[{bold:true,color:"blue",text:"Join"},{bold:false,text:" "},"Blue"]],click_event:{action:"run_command",command:"trigger LobbyWarp set 3"},hover_event:{action:"show_text",value:{italic:true,text:"Click to teleport to the Blue join pad."}}},"\n",{color:"gray",text:"* ",extra:[[{bold:true,color:"gold",text:"Join"},{bold:false,text:" "},"Yellow"]],click_event:{action:"run_command",command:"trigger LobbyWarp set 4"},hover_event:{action:"show_text",value:{italic:true,text:"Click to teleport to the Yellow join pad."}}}]
execute unless predicate game:gamemode_components/one_team if predicate game:gamemode_components/red_for_blue run data modify storage rocketriders:navbook join_teams set value ["",{color:"gray",text:"* ",extra:[[{bold:true,color:"dark_red",text:"Join"},{bold:false,text:" "},"Red"]],click_event:{action:"run_command",command:"trigger LobbyWarp set 3"},hover_event:{action:"show_text",value:{italic:true,text:"Click to teleport to the Red join pad."}}},"\n",{color:"gray",text:"* ",extra:[[{bold:true,color:"gold",text:"Join"},{bold:false,text:" "},"Yellow"]],click_event:{action:"run_command",command:"trigger LobbyWarp set 4"},hover_event:{action:"show_text",value:{italic:true,text:"Click to teleport to the Yellow join pad."}}}]
execute if predicate game:gamemode_components/one_team unless predicate game:gamemode_components/red_for_blue run data modify storage rocketriders:navbook join_teams set value ["",{color:"gray",text:"* ",extra:[[{bold:true,color:"blue",text :"Join"},{bold:false,text:" "},"Match"]],click_event:{action:"run_command",command:"trigger LobbyWarp set 3"},hover_event:{action:"show_text",value:{italic:true,text:"Click to teleport to a join pad."}}}]
execute if predicate game:gamemode_components/one_team if predicate game:gamemode_components/red_for_blue run data modify storage rocketriders:navbook join_teams set value ["",{color:"gray",text:"* ",extra:[[{bold:true,color:"dark_red",text :"Join"},{bold:false,text:" "},"Match"]],click_event:{action:"run_command",command:"trigger LobbyWarp set 3"},hover_event:{action:"show_text",value:{italic:true,text:"Click to teleport to a join pad."}}}]
execute if predicate game:gamemode_components/one_team run data modify storage rocketriders:navbook first_page_spacing append value "\n"

# description
data modify storage rocketriders:navbook description set value {color:"dark_gray",text:"\nRocket Riders is a tactical game where two teams ride missiles to the enemy base to destroy their portals.\n\nIn the Modification Room, you can easily customize the game with many gamemodes, modifiers, and other settings to play with."}
execute if predicate rr:server_mode/cubekrowd_voting run data modify storage rocketriders:navbook description set value {color:"dark_gray",text:"\nRocket Riders is a tactical game where two teams ride missiles to the enemy base to destroy their portals.\n\nAfter each game, you can vote between several gamemodes, modifiers, and base designs to play with for the next round."}
execute if predicate rr:server_mode/cubekrowd_duels run data modify storage rocketriders:navbook description set value {color:"dark_gray",text:"\nRocket Riders is a tactical game where two teams ride missiles to the enemy base to destroy their portals.\n\nIn 1v1 Duel Mode, players challenge each other to a best of three, one-on-one tournament with sets of 12 random items."}

# modroom / edit settings
data modify storage rocketriders:navbook modroom set value ""
execute if predicate rr:has_modification_room if predicate lobby:open_modification_room run data modify storage rocketriders:navbook modroom set value ["\n",{text:"* ",color:"gray",hover_event:{action:"show_text",value:{text:"Click to teleport to the Modification Room.",italic:true}},click_event:{action:"run_command","command":"trigger LobbyWarp set 2"}},{text:"Modification Room",color:"dark_purple",hover_event:{action:"show_text",value:{text:"Click to teleport to the Modification Room.",italic:true}},click_event:{action:"run_command","command":"trigger LobbyWarp set 2"}}]
scoreboard players set $can_edit_settings var 0
execute if predicate rr:has_modification_room unless predicate lobby:open_modification_room if predicate game:phase/staging/queue unless predicate game:game_rules/lock_modification_room/on run data modify storage rocketriders:navbook modroom set value ["\n",{text:"* ",color:"gray",hover_event:{action:"show_text",value:{text:"Click to stop the match from starting and open the modification room.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}},{text:"Edit Settings",color:"dark_purple",hover_event:{action:"show_text",value:{text:"Click to stop the match from starting and open the modification room.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}}]
execute if predicate rr:has_modification_room unless predicate lobby:open_modification_room if predicate game:phase/staging/queue if predicate game:game_rules/lock_modification_room/on run data modify storage rocketriders:navbook modroom set value ["\n",{text:"* ",color:"gray",hover_event:{action:"show_text",value:{text:"Click to stop the match from starting.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}},{text:"Edit Settings",color:"dark_purple",hover_event:{action:"show_text",value:{text:"Click to stop the match from starting.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}}]
execute if predicate rr:has_modification_room unless predicate lobby:open_modification_room if predicate game:phase/match if score $playing_teams_count global matches 0 unless predicate game:game_rules/lock_modification_room/on run data modify storage rocketriders:navbook modroom set value ["\n",{text:"* ",color:"gray",hover_event:{action:"show_text",value:{text:"Click to stop the match and open the modification room.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}},{text:"Edit Settings",color:"dark_purple",hover_event:{action:"show_text",value:{text:"Click to stop the match and open the modification room.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}}]
execute if predicate rr:has_modification_room unless predicate lobby:open_modification_room if predicate game:phase/match if score $playing_teams_count global matches 0 if predicate game:game_rules/lock_modification_room/on run data modify storage rocketriders:navbook modroom set value ["\n",{text:"* ",color:"gray",hover_event:{action:"show_text",value:{text:"Click to stop the match.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}},{text:"Edit Settings",color:"dark_purple",hover_event:{action:"show_text",value:{text:"Click to stop the match.",italic:true}},click_event:{action:"run_command","command":"trigger editSettings"}}]
execute if data storage rocketriders:navbook {modroom:""} run data modify storage rocketriders:navbook first_page_spacing append value "\n"

# parkour instructions
data modify storage rocketriders:navbook parkourtips set value ""
execute if predicate rr:has_parkour run data modify storage rocketriders:navbook parkourtips set value ["\n\n",{bold:true,text:"\N{ZERO WIDTH NON-JOINER}"},[{text:"[Parkour",color:"dark_gray",hover_event:{action:"show_text",value:{text:"Click to toggle Parkour instructions.",italic:true}},click_event:{action:"run_command",command:"trigger toggle_parkour_instructions set 1"}},{bold:true,text:"\N{ZERO WIDTH NON-JOINER}\N{ZERO WIDTH NON-JOINER}"},"Instructions]"]]

# default spell book and starting crusade kit settings
data modify storage rocketriders:navbook crusade_mode_settings set value ""
execute in minecraft:overworld if entity @e[limit=1,x=0,type=armor_stand,tag=gamemodeAS,tag=rr_crusade] run data modify storage rocketriders:navbook crusade_mode_settings set value ["\n\n  ",{text:"[Default Spell Book]",color:"dark_gray",hover_event:{action:"show_text",value:{text:"Click to change your default Spell Book in Crusade mode.",italic:true}},click_event:{action:"run_command",command:"trigger change_default_spell set 1"}},{bold:true,text:"\n\N{ZERO WIDTH NON-JOINER}\N{ZERO WIDTH NON-JOINER}"},{text:"[Starting Crusade Kit]",color:"dark_gray",hover_event:{action:"show_text",value:{text:"Click to change your starting kit in Crusade mode.",italic:true}},click_event:{action:"run_command",command:"trigger change_starting_crusade_kit set 1"}}]

# resolve
execute in minecraft:overworld summon minecraft:item_display run function lobby:__update_nav_book/resolve

# update online players
execute in minecraft:overworld as @a[x=0] if items entity @s hotbar.4 *[custom_data~{navbook:true}] run function lobby:give_nav_book with storage rocketriders:navbook item
