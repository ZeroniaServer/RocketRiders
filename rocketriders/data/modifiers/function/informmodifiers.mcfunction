##Notifies specific players of active Modifiers
execute store success score $at_least_one_modifier_enabled var unless entity @s[predicate=!game:modifiers/instamine/on,predicate=!game:modifiers/no_fall_damage/on,predicate=!game:modifiers/explosive/on,predicate=!game:modifiers/rocket_residers/on,predicate=!game:modifiers/sonar/on,predicate=!game:modifiers/molerat/on,predicate=!game:modifiers/minute_mix/on,predicate=!game:modifiers/special_treatment/on,predicate=!game:modifiers/wind_down/on,predicate=!game:modifiers/splash_streams/on,predicate=!game:modifiers/spam_click/on,predicate=!game:modifiers/ninja_jump/on,predicate=!game:modifiers/hardcore/on,predicate=!game:modifiers/double_portal/on,predicate=!game:modifiers/clutter_collector/on,predicate=!game:modifiers/special_treatment/on,predicate=!game:modifiers/collision_control/on,predicate=!game:modifiers/punchable_tnt/on,predicate=!game:modifiers/unstable_tnt/on,predicate=!game:modifiers/hobbits/on,predicate=!game:modifiers/instant_tnt_explosions/on,predicate=!game:modifiers/long_arms/on]

execute unless entity @s[predicate=rr:server_mode/cubekrowd_voting,predicate=!game:gamemode_components/duel_settings_locked] unless predicate rr:server_mode/cubekrowd_duels if score $at_least_one_modifier_enabled var matches 1 run tellraw @a[x=0,tag=informMe] ["",{"text":"|","bold":true,"color":"dark_gray"},{"text":" Modifiers:","color":"dark_aqua"},{"text":" (hover names for info)","color":"dark_gray","italic":true}]
execute if predicate rr:has_modifiers if score $at_least_one_modifier_enabled var matches 1 run function modifiers:generatelist
execute if predicate rr:has_modifiers if score $at_least_one_modifier_enabled var matches 1 run function modifiers:printlistinform
execute if predicate rr:has_modifiers if score $at_least_one_modifier_enabled var matches 0 run tellraw @a[x=0,tag=informMe] ["",{"text":"|","bold":true,"color":"dark_gray"},{"text":" Modifiers:","color":"dark_aqua"},{"text":" None ","color":"aqua"}]
execute if predicate rr:server_mode/cubekrowd_duels run tellraw @a[x=0,tag=informMe] ["",{"text":"|","bold":true,"color":"dark_gray"},{"text":" Modifiers:","color":"dark_aqua"},{"text":" Wind Down","color":"aqua","hover_event":{"action":"show_text","value":["",{"text":"After every item given, the time between receiving items decreases, intensifying the match as it continues.","color":"white"}]}},{"text":" (hover name for info)","color":"dark_gray","italic":true}]

#Also notifies about Game Rules
execute unless entity @s[predicate=rr:server_mode/cubekrowd_voting,predicate=!game:gamemode_components/duel_settings_locked] unless predicate rr:server_mode/cubekrowd_duels run tellraw @a[x=0,tag=informMe] ["",{"text":"|","bold":true,"color":"dark_gray"},{"text":" Game Rules","color":"yellow","hover_event":{"action":"show_text","value":[{"storage":"rocketriders:gamerules","nbt":"list[]","interpret":true,"separator":{"text":"\n"}}]}},{"text":" (hover for info)","color":"dark_gray","italic":true}]

execute if predicate rr:has_modifiers unless predicate game:repeat_settings/finite unless entity @s[tag=duelEnabled,predicate=game:phase/match/play] run tellraw @a[x=0,tag=informMe] [{"text":""}]
execute if predicate rr:server_mode/cubekrowd_duels run tellraw @a[x=0,tag=informMe] [{"text":""}]