# Make sure "var" and "global" dummy objectives are initialised
scoreboard objectives add global dummy
scoreboard objectives add var dummy

# Prevent `#rr:tick` from running before all set-up has been completed
scoreboard players set $tick global 0

# Forceload all chunks that intsersect with the 2D region from -163 -175 to 187 175
execute in minecraft:overworld run forceload add -163 -175 76 64
execute in minecraft:overworld run forceload add 77 -175 187 80
execute in minecraft:overworld run forceload add -163 65 92 175
execute in minecraft:overworld run forceload add 77 65 187 175

# Wait until all chunks are loaded
scoreboard players set $forceloaded_region var 0
