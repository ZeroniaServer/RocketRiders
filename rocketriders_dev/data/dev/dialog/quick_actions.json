{
  "type": "minecraft:multi_action",
  "title": "RR Developer Actions",
  "external_title": "RR Developer Actions...",
  "actions": [
    {
      "action": {
        "type": "minecraft:run_command",
        "command": "/trigger dev set 2"
      },
      "label": "Force Stop"
    },
    {
      "action": {
        "type": "minecraft:run_command",
        "command": "/trigger dev set 3"
      },
      "label": "Force Start"
    },
    {
      "action": {
        "type": "minecraft:run_command",
        "command": "/trigger dev set 100"
      },
      "label": "Quick Launch",
      "tooltip": "Start a match with current game mode & settings."
    },
    {
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "dev:quick_actions/quick_launch_gamemode"
      },
      "label": "Quick Launch Game Mode...",
      "tooltip": "Start a match on a specific game mode."
    },
    {
      "action": {
        "type": "minecraft:run_command",
        "command": "/trigger dev set 4"
      },
      "label": "Join/Leave Match",
      "tooltip": "If in the lobby or developer mode, automatically adds you to a team.\n\nIf playing or spectating, returns you to the lobby."
    },
    {
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "dev:quick_actions/other_actions"
      },
      "label": {
        "italic": true,
        "text": "Other Actions..."
      }
    },
    {
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "dev:quick_actions/switch_team"
      },
      "label": "Switch Team...",
      "tooltip": "Choose a team to join."
    },
    {
      "action": {
        "type": "minecraft:run_command",
        "command": "/trigger dev set 12"
      },
      "label": "Toggle Developer Mode",
      "tooltip": "Moves you to the Developer team in creative mode (to bypass game mode restrictions) or back to the Lobby team in adventure mode."
    }
  ],
  "exit_action": {
    "label": "Cancel"
  }
}
