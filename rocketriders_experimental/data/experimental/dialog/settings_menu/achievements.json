{
  "actions": [
    {
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": {
          "type": "minecraft:multi_action",
          "title": "Rocket Riders",
          "body": {
            "type": "minecraft:plain_message",
            "contents": {
              "text": "Are you sure you want to reset all of your achievements?\n\nThis cannot be undone.",
              "color": "red"
            },
            "width": 400
          },
          "exit_action": {
            "label": {
              "translate": "gui.cancel"
            }
          },
          "actions": [
            {
              "label": "Confirm Reset",
              "action": {
                "type": "minecraft:run_command",
                "command": "trigger settings set 102"
              }
            }
          ]
        }
      },
      "label": "Reset All Achievements"
    }
  ],
  "after_action": "none",
  "exit_action": {
    "action": {
      "command": "trigger settings set -1",
      "type": "minecraft:run_command"
    },
    "label": {
      "translate": "gui.done"
    }
  },
  "pause": false,
  "title": "Rocket Riders",
  "type": "minecraft:multi_action"
}
