#Bossbars
function rr_ctf:everytick/bossbars

#Deliver Yellow flag at Blue base
execute as @e[x=0,type=player,tag=carrying_flag.yellow_right,predicate=custom:team/blue,predicate=custom:player/in_own_flag_capturing_zone] run scoreboard players add $flags_captured_by_blue global 1
execute as @e[x=0,type=player,tag=carrying_flag.yellow_right,predicate=custom:team/blue,predicate=custom:player/in_own_flag_capturing_zone] run scoreboard players display numberformat $blue ctf_sidebar fixed ["",{score:{name:"$flags_captured_by_blue",objective:"global"},color:red,bold:true},{text:"/2 ",color:white},{score:{name:"#yellow",objective:"text.flag"}}]
execute as @e[x=0,type=player,tag=carrying_flag.yellow_right,predicate=custom:team/blue,predicate=custom:player/in_own_flag_capturing_zone] as @a[x=0,predicate=custom:team/blue] at @s run playsound minecraft:block.note_block.bell master @s ~ ~ ~ 1 1.2
execute as @e[x=0,type=player,tag=carrying_flag.yellow_right,predicate=custom:team/blue,predicate=custom:player/in_own_flag_capturing_zone] as @a[x=0,predicate=custom:team/blue] at @s run playsound minecraft:block.note_block.bell master @s ~ ~ ~ 1 0.75
execute as @e[x=0,type=player,tag=carrying_flag.yellow_right,predicate=custom:team/blue,predicate=custom:player/in_own_flag_capturing_zone] as @a[x=0,predicate=custom:team/yellow] at @s run playsound minecraft:entity.wither.death master @s ~ ~ ~ 1 1
execute as @e[x=0,type=player,tag=carrying_flag.yellow_right,predicate=custom:team/blue,predicate=custom:player/in_own_flag_capturing_zone] run tellraw @a[x=0,predicate=custom:team/blue] [{score:{name:"#yellow",objective:"text.accent_color"}},"\n",{color:"green",text:"✔ "},{selector:"@s"}," successfully captured a ",[{score:{name:"#yellow",objective:"text.main_color"}},{score:{name:"#yellow",objective:"text.team_name"}}]," flag!\n"]
