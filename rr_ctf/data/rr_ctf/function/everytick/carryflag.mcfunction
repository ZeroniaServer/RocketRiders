effect give @a[x=0,predicate=custom:player/is_carrying_flag,scores={carrying_flag_time=1}] strength 20 0 false
effect give @a[x=0,predicate=custom:player/is_carrying_flag,scores={carrying_flag_time=1}] absorption infinite 0 true

