kill @e[x=0,type=marker,tag=rng2]

execute unless entity @e[x=0,type=end_crystal,tag=PUCrystalPerma] run scoreboard players add @e[x=0,type=marker,tag=captureMiddle,tag=!BrokenPlatform] CmdData 2
